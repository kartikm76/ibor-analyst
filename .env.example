# Single .env for the entire ibor-analyst stack — copy to .env and fill in real values.
# Read by: docker-compose (variable substitution) + Python gateway (python-dotenv)
# Never commit .env (gitignored).

# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Optional overrides (defaults shown) ──────────────────────────────────────
# PG_DSN=postgresql://ibor:ibor@localhost:5432/ibor
# STRUCTURED_API_BASE=http://localhost:8080/api
# ANTHROPIC_MODEL=claude-sonnet-4-6
